        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Custo M├®dio por Revis├úo (Geral)</div>
        <div style="font-size: 20px; font-weight: 800;" id="detalhe-custo-geral">R$ 0,00</div>
      </div>
      <div style="background: white; padding: 16px 20px;">
        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Custo M├®dio por Revis├úo (Com Pe├ºa)</div>
        <div style="font-size: 20px; font-weight: 800;" id="detalhe-custo-com-peca">R$ 0,00</div>
      </div>
      
      <!-- Linha 4 -->
      <div style="background: white; padding: 16px 20px;">
        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">M├®dia de Pe├ºas por M├íquina</div>
