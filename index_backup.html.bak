        <div style="font-size: 20px; font-weight: 800; color: var(--text); cursor: help;" id="remanu-detalhe-peca-top" title="Passe o mouse para ver a descri├º├úo completa">ÔÇö</div>
      </div>

      <!-- Linha 3 -->
      <div style="background: white; padding: 16px 20px;">
        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Valor da Fus├úo Nova</div>
