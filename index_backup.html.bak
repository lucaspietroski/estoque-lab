        <div style="font-size: 20px; font-weight: 800;" id="detalhe-com-peca">0</div>
      </div>
      <div style="background: white; padding: 16px 20px;">
        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Revisada sem Pe├ºa</div>
        <div style="font-size: 20px; font-weight: 800;" id="detalhe-sem-peca">0</div>
      </div>
      
      <!-- Linha 2 -->
