    <div class="modal-actions" style="margin-top:20px;">
      <button class="btn-cancel" onclick="document.getElementById('modal-ajuste-historico').classList.remove('open')">Cancelar</button>
      <button class="btn-confirm" id="btn-salvar-ajuste-hist">Salvar Ajuste</button>
    </div>
  </div>
</div>

<!-- MODAL V├ìNCULOS REMANUFATURA (NOVO VS RS) -->
<div class="modal-overlay" id="modal-vinculos-remanu">
  <div class="modal-box" style="max-width: 500px;">
    <h3>­ƒöù Vincular Fus├Áes (Nova vs RS)</h3>
    <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 20px;">
      Use esta tela para cadastrar os c├│digos de fus├Áes correspondentes a cada modelo de equipamento.
    </p>

    <div class="modal-label">MODELO DO EQUIPAMENTO</div>
    <input type="text" id="vinc-modelo" list="list-modelos-remanu" class="modal-input" placeholder="Ex: RICOH IM 430F">
    <datalist id="list-modelos-remanu"></datalist>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
      <div>
        <div class="modal-label">C├ôDIGO PE├çA NOVA</div>
        <input type="text" id="vinc-nova" class="modal-input" placeholder="Ex: D0A44164" style="text-transform: uppercase;">
      </div>
      <div>
        <div class="modal-label">C├ôDIGO PE├çA RS</div>
        <input type="text" id="vinc-rs" class="modal-input" placeholder="Ex: D0A44164RS" style="text-transform: uppercase;">
      </div>
    </div>

    <div class="modal-btns" style="margin-top: 10px;">
      <button class="btn-confirm" id="btn-salvar-vinculo" onclick="salvarVinculoRemanu()" style="width: 100%;">Salvar V├¡nculo</button>
    </div>

    <h3 style="font-size: 14px; margin-top: 30px; border-bottom: 1px solid var(--border); padding-bottom: 8px;">V├¡nculos Cadastrados</h3>
    <div style="max-height: 200px; overflow-y: auto; margin-top: 10px; border: 1px solid var(--border); border-radius: 8px;">
      <table class="dash-table" style="font-size: 12px; margin-top: 0;">
        <thead>
          <tr>
            <th style="text-align: left;">Modelo</th>
            <th style="text-align: center;">Nova</th>
            <th style="text-align: center;">RS</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="tbody-vinculos-remanu">
          <tr><td colspan="4" class="text-center">Nenhum v├¡nculo.</td></tr>
        </tbody>
      </table>
    </div>

    <div class="modal-btns" style="margin-top: 20px;">
      <button class="btn-cancel" onclick="document.getElementById('modal-vinculos-remanu').classList.remove('open')" style="width: 100%;">Fechar Janela</button>
    </div>
  </div>
</div>

<!-- MODAL SENHA AJUSTE AUTOM├üTICO DE ESTOQUE -->
<div class="modal-overlay" id="modal-audit-ajuste">
  <div class="modal-box" style="max-width: 450px;">
    <h3>ÔÜí Ajustar Estoque do Sistema</h3>
    <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 20px;">
      Esta a├º├úo ir├í sincronizar permanentemente as quantidades do sistema com as bipadas fisicamente nesta auditoria. <strong>Isso gerar├í lan├ºamentos autom├íticos no hist├│rico.</strong>
    </p>

    <div style="background: var(--red-light); border: 1px solid #f87171; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
      <h4 style="color: #991b1b; margin-top: 0; margin-bottom: 5px; font-size: 13px;">ÔÜá´©Å Rastreabilidade Garantida</h4>
      <p style="font-size: 11px; color: #7f1d1d; margin: 0;">
        Todos os lan├ºamentos de corre├º├úo (Sobras/Entradas e Faltas/Sa├¡das) ser├úo marcados no hist├│rico geral do sistema com o seu usu├írio e o ID desta sess├úo.
      </p>
    </div>

    <div class="form-group">
      <label class="modal-label">Digite a Senha de Auditoria</label>
      <input type="password" id="audit-ajuste-senha" class="modal-input" placeholder="Senha do Auditor" style="text-align: center; font-size: 16px; letter-spacing: 2px;">
      <span id="audit-ajuste-err" style="color: var(--red); font-size: 11px; font-weight: 700; margin-top: 5px; display: block; text-align: center;"></span>
    </div>

    <div class="modal-actions" style="margin-top: 25px; display: flex; gap: 10px;">
      <button class="btn-cancel" onclick="document.getElementById('modal-audit-ajuste').classList.remove('open')" style="flex: 1; border-radius: 8px; height: 40px;">Cancelar</button>
      <button class="btn-confirm" onclick="window.confirmarAjusteEstoque()" style="flex: 1; border-radius: 8px; height: 40px; background: var(--orange);">Confirmar Ajuste</button>
    </div>
  </div>
</div>

<!-- OVERLAY DE REPETI├ç├âO/REDEFINI├ç├âO DE SENHA -->
<div id="modal-reset-password" class="modal-overlay" style="display:none; align-items: center; justify-content: center; z-index: 10000; backdrop-filter: blur(15px); background: rgba(15, 23, 42, 0.85);">
  <div class="modal-box" style="width: 400px; background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 30px; text-align: left; box-shadow: 0 20px 40px rgba(0,0,0,0.3);">
    <h3 style="font-size: 18px; font-weight: 800; margin-bottom: 10px; color: var(--text); display: flex; align-items: center; gap: 8px;">­ƒöÆ Redefinir Senha</h3>
    <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 20px; line-height: 1.4;">
      Digite e confirme a sua nova senha de acesso ao sistema.
    </p>
    
    <div style="margin-bottom: 15px;">
      <div class="modal-label">Nova Senha</div>
      <input type="password" class="modal-input" id="reset-new-pass" placeholder="M├¡nimo 6 caracteres" style="margin-bottom: 0;">
    </div>
    <div style="margin-bottom: 15px;">
      <div class="modal-label">Confirmar Nova Senha</div>
      <input type="password" class="modal-input" id="reset-confirm-pass" placeholder="Confirme sua nova senha" style="margin-bottom: 0;">
    </div>
    
    <div class="modal-err" id="reset-pass-err" style="min-height: 1.2rem; font-weight: 600; text-align: center;"></div>
    
    <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 15px;">
      <button class="btn-confirm" id="btn-reset-pass-confirm">Atualizar Senha</button>
    </div>
  </div>
</div>

<script type="module" src="src/debug-center.js"></script>
<script type="module" src="src/main.js?v=1.5"></script>
</body>
</html>
