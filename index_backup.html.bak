<!-- MODAL AJUSTE HIST├ôRICO -->
<div id="modal-ajuste-historico" class="modal-overlay">
  <div class="modal-content">
    <h2>Ajustar Registro Hist├│rico</h2>
    <div class="form-group" style="margin-top:15px;">
      <label>Nova Quantidade</label>
      <input type="number" id="hist-ajuste-qty" min="1" class="modal-input" placeholder="Qtd">
    </div>
    <div class="form-group">
      <label>Valor Total do Registro (R$)</label>
      <input type="text" id="hist-ajuste-valor" class="modal-input" placeholder="Ex: 150,00">
    </div>
    <div class="form-group">
      <label>Motivo do Ajuste</label>
      <input type="text" id="hist-ajuste-motivo" class="modal-input" placeholder="Ex: Corre├º├úo de digita├º├úo">
