        <!-- Coluna da Direita: Gr├ífico e Tabela -->
        <div>
          <div class="chart-container-premium">
            <div class="chart-header">­ƒÆ░ TOP 10 MODELOS POR CUSTO M├ëDIO POR REVIS├âO (GERAL)</div>
            <div style="height: 400px; position: relative;">
              <canvas id="chart-modelo"></canvas>
            </div>
          </div>

          <!-- Tabela Compacta Abaixo -->
          <div class="card" style="margin-top: 25px; background: white; border-radius: 12px; border: 1px solid var(--border); overflow: hidden;">
            <div class="table-wrap" style="max-height: 400px; overflow-y: auto;">
              <table class="dash-table">
                <thead>
                  <tr id="mod-thead-tr">
                    <th style="text-align: left; padding: 12px;">Modelo</th>
                    <th class="text-center" style="padding: 12px;">Atendimentos</th>
                    <th class="text-center" style="padding: 12px;">Pe├ºas Usadas</th>
                    <th style="text-align: right; padding: 12px;">Custo Total</th>
                    <th style="text-align: right; padding: 12px;">M├®dia p/ Atend.</th>
                  </tr>
