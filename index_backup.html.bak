        <div style="font-size: 20px; font-weight: 800; font-family: var(--mono);" id="detalhe-custo-total">R$ 0,00</div>
      </div>
    </div>

    <!-- BODY PARA REMANUFATURA -->
    <div id="detalhe-body-remanu" style="display: none; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); padding: 1px;">
