              <div class="mod-kpi-label">MODELO MAIS BARATO ­ƒöì</div>
              <div class="mod-kpi-value" id="remanu-kpi-bottom" style="font-size: 15px; color: #1e293b;">ÔÇö</div>
              <div class="mod-kpi-sub" id="remanu-kpi-bottom-val" style="font-weight: 700;">R$ 0,00</div>
            </div>
