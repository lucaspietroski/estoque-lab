    <div id="modal-price-preview" style="font-size: 12px; color: var(--green); margin-top: 5px; font-weight: 500;">
      ­ƒæü´©Å Custo Real Equivalente (Vis├úo Atual): R$ 0.00
    </div>
    <div class="modal-label">Observa├º├úo / Motivo do Ajuste *</div>
    <input type="text" class="modal-input" id="modal-obs" placeholder="Ex: Corre├º├úo de invent├írio f├¡sico" required>
    <div class="modal-btns">
      <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
      <button class="btn-confirm" onclick="savePriceModal()">Salvar Altera├º├Áes</button>
    </div>
  </div>
</div>

<!-- MENU ADMIN OVERLAY (ENGRENAGEM) -->
<div class="modal-overlay" id="admin-menu-overlay" style="align-items: flex-start; justify-content: flex-end; padding: 20px;">
  <div class="modal-box" style="width: 320px; margin: 0; box-shadow: -4px 4px 20px rgba(0,0,0,0.1);">
    <div id="admin-menu-box">
      <h3 style="margin-bottom: 20px;">ÔÜÖ´©Å Administrativo</h3>
      <div style="display: flex; flex-direction: column; gap: 10px;">
        <button id="admin-btn-import-xml" class="btn-admin" style="width: 100%; justify-content: center;" onclick="openImportFromMenu()">­ƒôÑ Importar Dados (XML Protheus)</button>
        <button id="admin-btn-modelo-custo" class="btn-admin" style="width: 100%; justify-content: center;" onclick="window.switchTab('modelo-custo'); closeAdminMenu();">­ƒôè Custo por Modelo (Financeiro)</button>
        <button id="admin-btn-import-wms" class="btn-admin" style="width: 100%; justify-content: center;" onclick="window.switchTab('bi-equipamentos'); closeAdminMenu();">­ƒôü Importar Base BI (WMS)</button>
        <button id="admin-btn-revisados" class="btn-admin" style="width: 100%; justify-content: center;" onclick="window.switchTab('revisados'); closeAdminMenu();">­ƒøá´©Å Registrar SELBs Revisados</button>
        <button id="admin-btn-vinculo-selb" class="btn-admin" style="width: 100%; justify-content: center; background: #0ea5e9; color: white;" onclick="openManualSELBModal()">­ƒöù Vincular SELB Manualmente</button>
        <button id="admin-btn-cadastro-peca" class="btn-admin" style="width: 100%; justify-content: center; background: #10b981; color: white;" onclick="openCadastroPecaModal()">Ô×ò Cadastrar Pe├ºa Nova</button>
        <button id="admin-btn-backup" class="btn-admin" style="width: 100%; justify-content: center; background: #8b5cf6;" onclick="gerarBackupCompleto()">­ƒôª Gerar Backup Completo (JSON)</button>
        <button id="btn-toggle-custo" class="btn-admin" style="width: 100%; justify-content: center; background: var(--bg-hover); color: var(--text);" onclick="window.toggleModeCusto()">­ƒÆ▓ Modo Custo Real (DESATIVADO)</button>
        <button class="btn-cancel" onclick="closeAdminMenu()" style="margin-top: 20px; width: 100%;">Fechar Menu</button>
      </div>
    </div>
    
    <div id="import-submenu-box" style="display:none">
      <h3 style="margin-bottom: 10px;">­ƒôÑ Importa├º├úo XML</h3>
      <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 20px; line-height: 1.4;">Selecione o arquivo XML exportado pelo Protheus. O sistema ir├í ler as Tags &lt;cProd&gt;, &lt;qCom&gt; e &lt;vUnCom&gt; para atualizar saldos e custos automaticamente.</p>
      
      <div style="margin-bottom: 15px; padding: 10px; background: var(--surface2); border: 1px solid var(--border); border-radius: 8px;">
        <div class="modal-label" style="margin-bottom: 8px;">Selecione o Setor Destino:</div>
        <div style="display: flex; gap: 15px;">
          <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; font-size: 13px; font-weight: 600;">
            <input type="radio" name="xml-sector" value="LAB" checked> Laborat├│rio
          </label>
          <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; font-size: 13px; font-weight: 600;">
            <input type="radio" name="xml-sector" value="REMANU"> Remanufatura
          </label>
        </div>
      </div>

      <div id="xml-drop-area" style="border: 2px dashed var(--border); padding: 20px; text-align: center; border-radius: 8px; margin-bottom: 20px;">
        <input type="file" id="xml-file-input" accept=".xml" onchange="processarXML(this.files[0])" style="display: none;">
        <label for="xml-file-input" style="cursor: pointer; color: var(--blue); font-weight: 500;">
          ­ƒôü Clique aqui para selecionar o arquivo XML
        </label>
      </div>

      <div style="display: flex; justify-content: flex-end;">
        <button class="btn-cancel" onclick="backToAdminMenu()">Voltar</button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL CADASTRO PE├çA NOVA -->
<div class="modal-overlay" id="modal-cadastro-peca">
  <div class="modal-box" style="max-width: 420px;">
    <h3 style="color: #10b981; display: flex; align-items: center; gap: 8px;">Ô×ò Cadastrar Nova Pe├ºa</h3>
    <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 20px;">
      Insira as informa├º├Áes b├ísicas para cadastrar a pe├ºa no banco de dados. Ela ficar├í dispon├¡vel para todas as movimenta├º├Áes e auditoria.
    </p>

    <div style="margin-bottom: 15px;">
      <div class="modal-label">C├│digo da Pe├ºa *</div>
      <input type="text" class="modal-input" id="cad-code" placeholder="Ex: 302LV94270" style="text-transform: uppercase;">
    </div>

    <div style="margin-bottom: 15px;">
      <div class="modal-label">Descri├º├úo Completa *</div>
      <input type="text" class="modal-input" id="cad-desc" placeholder="Ex: CONJUNTO ROLETES DE ALIMENTACAO KYOCERA">
    </div>

    <div style="margin-bottom: 15px;">
      <div class="modal-label">Marca (Opcional)</div>
      <input type="text" class="modal-input" id="cad-marca" placeholder="Ex: KYOCERA" list="marcas-sugestoes">
      <datalist id="marcas-sugestoes">
        <option value="RICOH">
        <option value="KYOCERA">
        <option value="BROTHER">
        <option value="SAMSUNG">
        <option value="HP">
        <option value="LEXMARK">
        <option value="OUTROS">
      </datalist>
    </div>

    <div style="margin-bottom: 20px;">
      <div class="modal-label">Valor do Produto (Custo de Venda Comercial R$) *</div>
      <input type="number" step="0.01" class="modal-input" id="cad-custo" placeholder="Ex: 150.00">
      <div id="cad-custo-preview" style="font-size: 12px; color: var(--green); margin-top: 5px; font-weight: 500;">
        ­ƒæü´©Å Custo Real Equivalente (Vis├úo Atual): R$ 0.00
      </div>
    </div>

    <div style="display: flex; gap: 10px;">
      <button class="btn-cancel" onclick="closeCadastroPecaModal()" style="flex: 1;">Cancelar</button>
      <button class="btn-confirm" onclick="saveCadastroPeca()" style="flex: 2; background: #10b981;">Salvar Pe├ºa</button>
    </div>
    <div id="cadastro-peca-status" style="margin-top: 15px; font-size: 13px; text-align: center;"></div>
  </div>
</div>

<!-- MODAL VINCULO MANUAL SELB -->
<div class="modal-overlay" id="modal-selb-manual">
  <div class="modal-box" style="max-width: 400px;">
