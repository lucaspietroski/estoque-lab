        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Total de M├íquinas</div>
        <div style="font-size: 20px; font-weight: 800;" id="detalhe-total-maquinas">0</div>
