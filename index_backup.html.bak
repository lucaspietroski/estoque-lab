            <div class="mod-kpi-content">
              <div class="mod-kpi-label">MODELO MAIS ECON├öMICO</div>
              <div class="mod-kpi-value" id="remanu-kpi-melhor" style="font-size: 1.2rem; line-height: 1.3">-</div>
              <div class="mod-kpi-sub">maior % de margem</div>
            </div>
          </div>
          <div class="mod-kpi-item c-expensive" style="cursor: pointer;" onclick="window.openDetalheModelo('expensive')">
            <div class="mod-kpi-icon">ÔÜá´©Å</div>
            <div class="mod-kpi-content">
              <div class="mod-kpi-label">MODELO MAIS CARO ­ƒöì</div>
              <div class="mod-kpi-value" id="remanu-kpi-top" style="font-size: 15px; color: #1e293b;">ÔÇö</div>
              <div class="mod-kpi-sub" id="remanu-kpi-top-val" style="font-weight: 700;">R$ 0,00</div>
            </div>
