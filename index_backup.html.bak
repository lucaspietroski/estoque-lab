        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Total de Fus├Áes Recuperadas</div>
        <div style="font-size: 20px; font-weight: 800;" id="remanu-detalhe-recup">0</div>
      </div>
      <div style="background: white; padding: 16px 20px;">
        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Custo M├®dio por Recupera├º├úo</div>
        <div style="font-size: 20px; font-weight: 800;" id="remanu-detalhe-custo-medio">R$ 0,00</div>
      </div>

      <!-- Linha 2 -->
      <div style="background: white; padding: 16px 20px;">
        <div style="font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">M├®dia de Pe├ºas por Recupera├º├úo</div>
        <div style="font-size: 20px; font-weight: 800;" id="remanu-detalhe-media-pecas">0,00</div>
